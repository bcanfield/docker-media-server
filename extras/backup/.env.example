# S3-compatible credentials (DigitalOcean Spaces, AWS, etc.)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Restic repository URL
# DigitalOcean Spaces: s3:nyc3.digitaloceanspaces.com/your-bucket/restic
RESTIC_REPOSITORY=s3:nyc3.digitaloceanspaces.com/your-bucket/restic

# Restic encryption password (SAVE THIS — you need it to restore)
RESTIC_PASSWORD=a-strong-encryption-password

# Directory to back up
BACKUP_PATH=/opt/config-root/config
