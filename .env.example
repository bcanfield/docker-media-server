# Your timezone, https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# UNIX PUID and PGID, find with: id $USER
PUID=1000
PGID=1000

# The directory where downloaded data will be stored
MEDIA_ROOT=/mnt/media

# The directory where your app configs will be stored.
# (This can be the same as the MEDIA_ROOT. I prefer to keep my app config and downloads on seperate drives)
CONFIG_ROOT=/opt/config-root

# SSD-backed directory for SABnzbd temporary/incomplete downloads.
# Speeds up unpacking significantly vs spinning disk.
SABNZBD_TEMP=/opt/sabnzbd-temp

# Tailscale auth key — generate at https://login.tailscale.com/admin/settings/keys
# Use a reusable key so the container can re-authenticate after restarts.
TS_AUTHKEY=tskey-auth-xxxx
# Hostname that appears in your tailnet (e.g., media-server → media-server.your-tailnet.ts.net)
TS_HOSTNAME=media-server

